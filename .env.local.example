# ──────────────────────────────────────────────────────────────
# IPMD — Variables d'environnement
# Copier ce fichier en `.env.local` puis renseigner vos clés Supabase.
# Tant que ces clés ne sont pas fournies, le site fonctionne en mode
# « démo » (les formulaires n'envoient rien à Supabase).
# ──────────────────────────────────────────────────────────────

# URL publique du projet Supabase (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique anon (Settings > API > Project API keys > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service role — UNIQUEMENT côté serveur, ne jamais exposer au client
# (Settings > API > Project API keys > service_role)
SUPABASE_SERVICE_ROLE_KEY=

# URL publique du site (utile pour les liens absolus, emails, etc.)
NEXT_PUBLIC_SITE_URL=https://www.ipmd.pro

# ──────────────────────────────────────────────────────────────
# Notifications email (Resend — https://resend.com)
# Optionnel : sans ces clés, les formulaires marchent quand même
# (la demande est enregistrée dans Supabase, simplement aucun email
# de notification n'est envoyé).
# ──────────────────────────────────────────────────────────────

# Clé API Resend (Dashboard Resend > API Keys) — SECRÈTE, côté serveur
RESEND_API_KEY=

# Adresse(s) destinataire(s) des notifications (séparées par des virgules)
RESEND_TO=info@ipmd.pro

# Adresse expéditeur. Par défaut "IPMD <onboarding@resend.dev>" (mode test
# Resend : ne délivre qu'à l'email du compte). Pour un envoi pro, vérifie
# le domaine ipmd.pro dans Resend puis mets ex. "IPMD <notifications@ipmd.pro>".
RESEND_FROM=
